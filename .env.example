ANTHROPIC_API_KEY=your_anthropic_api_key

# GitHub — optional, raises rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=your_github_token

# LinkedIn — option 1: li_at cookie (fastest, most reliable)
# Get it from browser DevTools → Application → Cookies → linkedin.com → li_at
LINKEDIN_COOKIE=your_li_at_cookie_value

# LinkedIn — option 2: exported browser cookies JSON (extracts li_at automatically)
# Export via EditThisCookie Chrome extension → save as JSON
LINKEDIN_COOKIES_PATH=/path/to/linkedin_cookies.json

# LinkedIn — option 3: auto-login with email/password
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# Tor IP rotation — optional, only needed if use_tor=True
# Leave blank if your torrc uses CookieAuthentication 1 (default on most distros)
# Set this if you configured HashedControlPassword in torrc
TOR_CONTROL_PASSWORD=
